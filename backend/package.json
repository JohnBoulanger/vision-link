{
  "name": "temping-platform",
  "version": "0.0.1",
  "description": "Temporary Staffing Platform",
  "main": "server.js",
  "scripts": {
    "start": "node src/server.js ${PORT:-3000}",
    "start:local": "node src/server.js 3000",
    "build": "cd ../frontend && npm install && npm run build && cd ../backend && npx prisma generate && npx prisma db push && npx prisma db seed",
    "seed": "node prisma/seed.js",
    "clean": "rm -rf prisma/dev.db* node_modules package-lock.json prisma/migrations/",
    "format": "prettier --write \"src/**/*.js\""
  },
  "author": "CSC309 Student, Winter 2026",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.3.1",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-jwt": "^8.5.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "prisma": "^6.3.1",
    "socket.io": "^4.8.3",
    "sqlite3": "^5.1.1",
    "uuid": "^11.1.0",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  }
}
